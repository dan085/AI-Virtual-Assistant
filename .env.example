# ============================================================
# EXAMPLE environment variables — copy to .env and fill in.
# NEVER commit a real .env file. NEVER paste service account
# private keys into source control.
# ============================================================

# -------- Firebase (public client config) --------
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# -------- Functions runtime (set via `firebase functions:secrets:set`) --------
# GEMINI_API_KEY           -> Google AI Studio / Vertex AI key for Genkit
# INSTAGRAM_ACCESS_TOKEN   -> Long-lived Instagram Graph API token
# INSTAGRAM_BUSINESS_ID    -> IG Business Account id linked to a FB Page
