rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------- Per-user data --------
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Chat conversations
      match /conversations/{conversationId} {
        allow read, write: if isOwner(userId);

        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Instagram posts (drafts + published) created by the user OR the agent
      match /instagramPosts/{postId} {
        allow read, write: if isOwner(userId);
      }

      // Reminders (created via the createReminder skill or directly)
      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }

      // Personal knowledge base searchable by the agent
      match /knowledge/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // -------- Agent catalog (public read, functions-only write) --------
    match /agents/{agentId} {
      // Any signed-in user can list/read the agent catalog to populate
      // the agent picker.
      allow read: if isSignedIn();
      // Writes happen via the seed script or an admin using the Admin SDK,
      // which bypasses these rules. Clients cannot modify agents.
      allow write: if false;
    }

    // -------- Default deny --------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
